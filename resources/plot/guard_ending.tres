[resource]
script = ExtResource("1_4yygb")
end_name = "Guard"
description = "The party went off without a hitch. Everybody had a great time and the cake arrived safely. Princess Bridgitte personally had a blast and can add yet another successful party to her achievement list to boast about. Karin and her guards got rewarded and gained a reputation as the best cake protectors in the kingdom. Mortimer was intercepted downtown while trying to get into the carriage carrying the birthday cake, but [ENTER WHAT HAPPENED BASED ON THE POTION]. Mortimer then got thrown into the castle dungeon, but being the rat he is he will for sure weasel his way out. "
